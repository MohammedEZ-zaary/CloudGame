{
  "name": "cloudGames",
  "version": "1.2.0",
  "main": "main.js",
  "author": "Mohammed Ez-Zaary <mohamedzaariy@gmail.com>",
  "description": "A cloud gaming application built with Electron",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.cloudgame.app",
    "productName": "CloudGame",
    "directories": {
      "output": "release/"
    },
    "files": [
      "main.js",
      "package.json",
      "src/**/*",
      ".env"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/cloud-game.ico",
      "publisherName": "Mohammed EZ-zaary"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/assets/cloud-game.icns",
      "category": "public.app-category.games",
      "hardenedRuntime": true
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/assets/icon.png",
      "category": "Game"
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "firebase": "^12.11.0",
    "megajs": "^1.3.7",
    "mongodb": "^7.1.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  }
}
